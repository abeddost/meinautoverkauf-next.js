# ============================================================
# MeinAutoPreis24 — Next.js environment variables
# Copy this file to .env.local and fill in the values.
# ============================================================

# ── Supabase (public — safe to expose to the browser) ──────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# ── Google Gemini (SERVER-ONLY — never add NEXT_PUBLIC_) ───
# Used exclusively in app/api/evaluate/route.ts (Edge Runtime).
GEMINI_API_KEY=your-gemini-api-key

# ── Google Analytics 4 (optional) ──────────────────────────
# Measurement ID is safe to expose; API Secret must stay server-side.
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
GA4_API_SECRET=your-ga4-api-secret

# ── Site URL (used for canonical URLs, sitemap, etc.) ───────
NEXT_PUBLIC_SITE_URL=https://www.meinautoverkauf.de

# ── Migration note ──────────────────────────────────────────
# Old Vite env vars → Next.js equivalents:
#   VITE_SUPABASE_URL       → NEXT_PUBLIC_SUPABASE_URL
#   VITE_SUPABASE_ANON_KEY  → NEXT_PUBLIC_SUPABASE_ANON_KEY
#   VITE_GEMINI_API_KEY     → GEMINI_API_KEY (server-only!)
#   VITE_GA_MEASUREMENT_ID  → NEXT_PUBLIC_GA_MEASUREMENT_ID
