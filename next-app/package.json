{
  "name": "meinautoverkauf-next",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "node scripts/assert-node-20.mjs",
    "dev": "next dev",
    "dev:clean": "npm run clean:dev && npm run dev",
    "clean:dev": "node scripts/clean-dev-cache.mjs",
    "prebuild": "node scripts/assert-node-20.mjs",
    "build": "next build",
    "prestart": "node scripts/assert-node-20.mjs",
    "start": "next start",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "type-check": "next typegen && tsc --noEmit",
    "lh:audit": "npm run build && node scripts/lighthouse-audit.mjs",
    "og:image": "node scripts/generate-og-image.mjs",
    "check:pagespeed": "node scripts/check-pagespeed-gate.mjs",
