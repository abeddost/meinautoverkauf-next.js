    "icons:favicon": "node scripts/generate-favicons.mjs",
    "images:webp": "node scripts/convert-png-to-webp.mjs --quality 80",
    "images:webp:dry-run": "node scripts/convert-png-to-webp.mjs --quality 80 --dry-run"
